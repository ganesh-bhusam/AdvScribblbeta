# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.

# Server port
PORT=8001

# JWT signing secret — generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_MIN_32_CHARS

# Razorpay payment keys (get from https://dashboard.razorpay.com)
# Set PAYMENT_MOCK_MODE=1 for local dev (no real Razorpay calls)
PAYMENT_MOCK_MODE=1
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME

# Allowed frontend origins (comma-separated, no trailing slash)
# e.g. http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Support email shown in ToS and password-reset alerts
SUPPORT_EMAIL=support@advscribbl.app
